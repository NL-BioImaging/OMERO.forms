{
  "$id": "https://example.org/schemas/lei_mihcsme",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "MIHCSME Template for High Throughput Screening (HTS)",
  "version": "3",
  "type": "object",
  "required": [
    "investigation_information",
    "study_information",
    "assay_information",
    "assay_conditions"
  ],
  "properties": {
    "template_info_text": {
      "type": "string",
      "title": "",
      "description": "Fixed template info (not entered by the user).",
      "default": "Template Version: LEI-MIHCSME_userTemplate_v3\nGenerated: Jan-20-2023\nCreated by: RH"
    },
    "investigation_information": {
      "$ref": "#/definitions/InvestigationInformationModule"
    },
    "study_information": {
      "$ref": "#/definitions/StudyInformationModule"
    },
    "assay_information": {
      "$ref": "#/definitions/AssayInformationModule"
    },
    "assay_conditions": {
      "$ref": "#/definitions/AssayConditionsTable"
    }
  },
  "definitions": {
    "InvestigationInformationModule": {
      "additionalProperties": false,
      "title": "InvestigationInformationModule",
      "type": "object",
      "properties": {
        "DataOwner_First_Name": {
          "type": [
            "string",
            "null"
          ],
          "description": "First Name"
        },
        "DataOwner_Middle_Name_s": {
          "type": [
            "string",
            "null"
          ],
          "description": "Middle Name(s) if any"
        },
        "DataOwner_Last_Name": {
          "type": [
            "string",
            "null"
          ],
          "description": "Last Name"
        },
        "DataOwner_User_name": {
          "type": [
            "string",
            "null"
          ],
          "description": "Institutional user name"
        },
        "DataOwner_Institute": {
          "type": [
            "string",
            "null"
          ],
          "description": "Institute level, eg. Universiteit Leiden, Faculty of Science, Institute of Biology"
        },
        "DataOwner_E_Mail_Address": {
          "type": [
            "string",
            "null"
          ],
          "description": "Institution email address"
        },
        "DataOwner_ORCID_investigator": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri",
          "description": "orcid id as url, eg. https://orcid.org/0000-0002-3704-3675"
        },
        "DataCollaborator_ORCID_Data_Collaborator": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri",
          "description": "ORCID is of collaborator with experimental, collection or analysis part of this investigation"
        },
        "DataCollaborator_ORCID_Data_Collaborator_2": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri",
          "description": "ORCID is of collaborator with experimental, collection or analysis part of this investigation"
        },
        "InvestigationInformation_Project_ID": {
          "type": [
            "string",
            "null"
          ],
          "description": "EU/NWO/consortium ID – Examples: EuTOX"
        },
        "InvestigationInformation_Investigation_Title": {
          "type": [
            "string",
            "null"
          ],
          "description": "High level concept to link related studies. Could be the main hypothesis/question you want to investigate as part of your research. Could be a chapter/thesis of your work."
        },
        "InvestigationInformation_Investigation_internal_ID": {
          "type": [
            "string",
            "null"
          ],
          "description": "Corresponding internal ID for your investigation."
        },
        "InvestigationInformation_Investigation_description": {
          "type": [
            "string",
            "null"
          ],
          "description": "Short description for your investigation."
        }
      }
    },
    "StudyInformationModule": {
      "additionalProperties": false,
      "title": "StudyInformationModule",
      "type": "object",
      "properties": {
        "Study_Study_Title": {
          "type": [
            "string",
            "null"
          ],
          "description": "Manuscript/chapter/publication/paragraph title describing purpose or intention for one or multiple assays (screens/experiments)"
        },
        "Study_Study_internal_ID": {
          "type": [
            "string",
            "null"
          ],
          "description": "Study ID, linked to ELN or lab journal"
        },
        "Study_Study_Description": {
          "type": [
            "string",
            "null"
          ],
          "description": "Description of study with additional unstructured information about this study possibly not covered elsewhere in this template."
        },
        "Study_Study_Key_Words": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          },
          "description": "List of key words associated with your study (EFO-terms). Examples: FDA approved drugs, Kinase inhibitors, DNA damage response, Unfolded protein response, Oxidative stress response, Inflammatory signaling, chemical similarity"
        },
        "Biosample_Biosample_Taxon": {
          "type": [
            "string",
            "null"
          ],
          "description": "NCBI-taxon id, human = NCBITAXON:9606;"
        },
        "Biosample_Biosample_description": {
          "type": [
            "string",
            "null"
          ],
          "description": "Description of biosample genotype; Additional unstructured information about organisms used in this experiment."
        },
        "Biosample_Biosample_Organism": {
          "type": [
            "string",
            "null"
          ],
          "description": "Which organism is your cell lines or tissue from. Examples: Human or mouse"
        },
        "Biosample_Number_of_cell_lines_used": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "In case multiple cell lines are used indicate here"
        },
        "Library_Library_File_Name": {
          "type": [
            "string",
            "null"
          ],
          "description": "Library file info"
        },
        "Library_Library_File_Format": {
          "type": [
            "string",
            "null"
          ],
          "description": "Library file info"
        },
        "Library_Library_Type": {
          "type": [
            "string",
            "null"
          ],
          "description": "Library file info"
        },
        "Library_Library_Manufacturer": {
          "type": [
            "string",
            "null"
          ],
          "description": "Library file info"
        },
        "Library_Library_Version": {
          "type": [
            "string",
            "null"
          ],
          "description": "Library file info"
        },
        "Library_Library_Experimental_Conditions": {
          "type": [
            "string",
            "null"
          ],
          "description": "Any experimental conditions some cells were grown under as part of the study enter the information here e.g. different environmental stress conditions, or mutant background compared to wild type."
        },
        "Library_Quality_Control_Description": {
          "type": [
            "string",
            "null"
          ],
          "description": "A brief description of the kind of quality control measures that were taken."
        },
        "Protocols_HCS_library_protocol": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri",
          "description": "Url/doi protocols.io or ELN associated url. At least SOP/protocol filename"
        },
        "Protocols_growth_protocol": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri",
          "description": "Url/doi protocols.io or ELN associated url. At least SOP/protocol filename"
        },
        "Protocols_treatment_protocol": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri",
          "description": "Url/doi protocols.io or ELN associated url. At least SOP/protocol filename"
        },
        "Protocols_HCS_data_analysis_protocol": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri",
          "description": "Url/doi protocols.io or ELN associated url. At least SOP/protocol filename"
        },
        "Plate_Plate_type": {
          "type": [
            "string",
            "null"
          ],
          "description": "Example: uclear"
        },
        "Plate_Plate_type_Manufacturer": {
          "type": [
            "string",
            "null"
          ],
          "description": "Example: Greiner Bio-One"
        },
        "Plate_Plate_type_Catalog_number": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "Example:781081"
        }
      }
    },
    "AssayInformationModule": {
      "additionalProperties": false,
      "title": "AssayInformationModule",
      "type": "object",
      "properties": {
        "Assay_Assay_Title": {
          "type": [
            "string",
            "null"
          ],
          "description": "Screen name"
        },
        "Assay_Assay_internal_ID": {
          "type": [
            "string",
            "null"
          ],
          "description": "Experimental ID, e.g. aMV-010, linked to ELN or labjournal"
        },
        "Assay_Assay_Description": {
          "type": [
            "string",
            "null"
          ],
          "description": "Description of screen plus additional unstructured information about screen not covered elsewhere. Stages of HCS: either primary screen, secondary screen or validation screen. EFO terms"
        },
        "Assay_Assay_number_of_biological_replicates": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "Total number of biol. Repl."
        },
        "Assay_Number_of_plates": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "Total number of plates, n-plates"
        },
        "Assay_Assay_Technology_Type": {
          "type": [
            "string",
            "null"
          ],
          "description": "Imaging method, Fbbi terms.",
          "$ref": "#/definitions/FBBIImagingMethods"
        },
        "Assay_Assay_Type": {
          "type": [
            "string",
            "null"
          ],
          "description": "List of options: sub types of HCS e.g. Gene Knock down, RNAi, compount,  EFO terms",
          "$ref": "#/definitions/EFOAssayTypes"
        },
        "Assay_Assay_External_URL": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri",
          "description": "ELN or any other external url link to this screen."
        },
        "Assay_Assay_data_URL": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri",
          "description": "OMERO url link to this screen."
        },
        "AssayComponent_Imaging_protocol": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri",
          "description": "Url to protocols.io or protocols in ELN, at least protocol file name or free text description of imaging protocol"
        },
        "AssayComponent_Sample_preparation_protocol": {
          "type": [
            "string",
            "null"
          ],
          "description": "Sample preparation method (Formaldahude (PFA) fixed tissue, Live cells, unfixed tissue). FBbi terms"
        },
        "Biosample_Cell_lines_storage_location": {
          "type": [
            "string",
            "null"
          ],
          "description": "Storage location according to Database used or at least location e.g. Example -150 liquid N2 tank 4th floor GE4.xx"
        },
        "Biosample_Cell_lines_clone_number": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "Storage location DB info"
        },
        "Biosample_Cell_lines_Passage_number": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "Passage number of your cells. In case different passage number is used for the replicates, please indicate it in Comment_users."
        },
        "ImageData_Image_number_of_pixelsX": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "Indicate number of pixels in x in images"
        },
        "ImageData_Image_number_of_pixelsY": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "Indicate number of pixels in y in images"
        },
        "ImageData_Image_number_of_z_stacks": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "Indicate number z stacks in image, single image is z=1"
        },
        "ImageData_Image_number_of_channels": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "Indicate number of channels in your image, single channel image c=1, including your TD channel"
        },
        "ImageData_Image_number_of_timepoints": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "Indicate number of time point(s) in your image"
        },
        "ImageData_Image_sites_per_well": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "Number of fields, numeric value"
        },
        "ImageAcquisition_Microscope_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri",
          "description": "Url to micrometa app file link or other url describing your microscope. At least Microscope name."
        },
        "Specimen_Channel_Transmission_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Channel id is dependent on different machines, first or last.  If No transmission is acquired state NA"
        },
        "Specimen_Channel_1_visualization_method": {
          "type": [
            "string",
            "null"
          ],
          "description": "Visualization method (example: Hoechst staining )"
        },
        "Specimen_Channel_1_entity": {
          "type": [
            "string",
            "null"
          ],
          "description": "Entity visualized (example: DNA )"
        },
        "Specimen_Channel_1_label": {
          "type": [
            "string",
            "null"
          ],
          "description": "Label used for entity (example:Nuclei) Best practice to use similar label as your CP-pipeline"
        },
        "Specimen_Channel_1_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "sequential id of channel order in your image"
        },
        "Specimen_Channel_2_visualization_method": {
          "type": [
            "string",
            "null"
          ],
          "description": "Visualization method (example: GFP )"
        },
        "Specimen_Channel_2_entity": {
          "type": [
            "string",
            "null"
          ],
          "description": "Entity visualized (example: MAP1LC3B )"
        },
        "Specimen_Channel_2_label": {
          "type": [
            "string",
            "null"
          ],
          "description": "Label used for entity (example:GFP-LC3) Best practice to use similar label as your CP-pipeline"
        },
        "Specimen_Channel_2_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "sequential id of channel order in your image"
        },
        "Specimen_Channel_3_visualization_method": {
          "type": [
            "string",
            "null"
          ],
          "description": "Visualization method (example: PI staining )"
        },
        "Specimen_Channel_3_entity": {
          "type": [
            "string",
            "null"
          ],
          "description": "Entity visualized (example: Death cell DNA )"
        },
        "Specimen_Channel_3_label": {
          "type": [
            "string",
            "null"
          ],
          "description": "Label used for entity (example:PI) Best practice to use similar label as your CP-pipeline"
        },
        "Specimen_Channel_3_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "sequential id of channel order in your image"
        },
        "Specimen_Channel_4_visualization_method": {
          "type": [
            "string",
            "null"
          ],
          "description": "Visualization method (example: Apoptotic marker Annexin V staining )"
        },
        "Specimen_Channel_4_entity": {
          "type": [
            "string",
            "null"
          ],
          "description": "Entity visualized (example: Apoptotic cells )"
        },
        "Specimen_Channel_4_label": {
          "type": [
            "string",
            "null"
          ],
          "description": "Label used for entity (example:Annexin-V) Best practice to use similar label as your CP-pipeline"
        },
        "Specimen_Channel_4_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "sequential id of channel order in your image"
        }
      }
    },
    "AssayConditionsTable": {
      "additionalProperties": false,
      "title": "AssayConditionsTable",
      "description": "List of each well and plate containing entity, dose and other characteristics required for your study.",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "Plate": {
            "type": [
              "string",
              "null"
            ],
            "description": "Plate value."
          },
          "Well": {
            "type": [
              "string",
              "null"
            ],
            "description": "Well value."
          },
          "Treatment": {
            "type": [
              "string",
              "null"
            ],
            "description": "Treatment value."
          },
          "Concentration": {
            "type": [
              "number",
              "null"
            ],
            "description": "Treatment concentration.",
            "minimum": 0
          },
          "Unit": {
            "type": [
              "string",
              "null"
            ],
            "description": "Unit value."
          },
          "CellLine": {
            "type": [
              "string",
              "null"
            ],
            "description": "CellLine value."
          },
          "TimeTreatment": {
            "type": [
              "string",
              "null"
            ],
            "description": "TimeTreatment value."
          },
          "RepID": {
            "type": [
              "string",
              "null"
            ],
            "description": "RepID value."
          }
        }
      }
    },
